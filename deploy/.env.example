# Argus Catalog — 운영 배포 시크릿/크리덴셜 템플릿.
#
#   cp deploy/.env.example deploy/.env   # 값을 채우고, 절대 커밋하지 말 것(.gitignore 대상)
#
# 강한 무작위 값 생성 예:
#   openssl rand -base64 36

# ── 카탈로그 서버 시크릿 (백엔드가 환경변수로 직접 읽음) ─────────────────────
ARGUS_SECRET_KEY=        # 외부 연동 자격증명 암호화 키 (Fernet). 미설정 시 개발용 기본키(운영 금지)
ARGUS_JWT_SECRET=        # 로컬 JWT 서명키. 미설정 시 개발용 기본키(운영 금지)

# ── 컨테이너 서비스 크리덴셜 ────────────────────────────────────────────────
# ⚠️ 백엔드는 DB·오브젝트 스토리지 접속정보를 config/config.properties 에서 읽는다.
#    아래 DB_PASSWORD / MINIO_* 값을 config/config.properties 의
#    db.password / os.access_key / os.secret_key 와 반드시 일치시킬 것.
#    (또는 외부 관리형 DB/S3/Temporal 로 전환 — README 운영 배포 참고)
DB_PASSWORD=             # catalog-postgres 비밀번호
MINIO_ROOT_USER=         # MinIO 액세스 키
MINIO_ROOT_PASSWORD=     # MinIO 시크릿 키
TEMPORAL_DB_PASSWORD=    # temporal 메타 DB 비밀번호

# ── 데이터 보관 경로(bind mount) ────────────────────────────────────────────
# DB·MinIO 데이터를 명시적 호스트 경로에 보관해 컨테이너 삭제/재생성에도 보존한다.
# 운영에서는 백업 가능한 절대 경로를 권장(예: /var/lib/argus-catalog/data).
# 상대 경로는 compose 파일 디렉터리(deploy/) 기준으로 해석된다.
DATA_DIR=./data

# ── 이미지 핀(운영 권장) ────────────────────────────────────────────────────
# 검증된 특정 버전으로 고정하세요(:latest 금지).
MINIO_IMAGE=minio/minio:latest
