# Argus Metadata Agent 설정 예시 — Docker/네이티브 공통.
# 우선순위: CLI 인자 > 환경변수 > 기본값

# 카탈로그 API (반입은 admin 권한 필요)
ARGUS_API_URL=http://localhost:4600
ARGUS_USERNAME=admin
ARGUS_PASSWORD=changeme

# LLM — OpenAI 호환 엔드포인트 (ollama 기본)
AGENT_LLM_URL=http://localhost:11434/v1
AGENT_MODEL=qwen2.5:7b
AGENT_LLM_API_KEY=ollama

# 동작: suggest(제안 — 사람 승인) | apply(직접 적용, PII 는 항상 제안)
AGENT_MODE=suggest
AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=2048

# worker 모드
AGENT_POLL_INTERVAL=300
AGENT_WORKER_TARGET=missing

# serve 모드 셀프-텔레메트리 — 카탈로그 AI Agent 레지스트리에 자신을 등록하고
# 채팅 호출 지표(지연·토큰·성공여부)를 push (베스트에포트). 레지스트리가 없는
# 환경이면 AGENT_TELEMETRY=off 로 끌 수 있다.
AGENT_NAME=argus-catalog-assistant
AGENT_TELEMETRY=on
